# The genesis engine the BFF proxy (app/api/chat/route.ts) forwards to.
# Local default; over Tailscale use the agent host, e.g.
#   GENESIS_URL=http://100.82.195.109:8787
GENESIS_URL=http://127.0.0.1:8787

# Optional bearer token. When set, the BFF injects
#   Authorization: Bearer ${GENESIS_TOKEN}
# on the server side — the browser never sees it. Leave blank for an
# unauthenticated local engine.
GENESIS_TOKEN=

# ─── Auth (Better Auth + passkey) ───────────────────────────────────────────
# Single-user passkey gate. See README "Auth" for the bootstrap → enroll flow.

# Signing secret for sessions/cookies. REQUIRED in production. Generate a random
# 32+ char value, e.g.:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical base URL of this app. Drives the passkey relying-party (rpID derives
# from the hostname) AND Better Auth's own baseURL. Use the exact public origin —
# WebAuthn binds each passkey to this host, so a mismatch breaks sign-in.
#   local:   http://localhost:3000
#   tailnet: https://srv1692698-agent.tailf3e897.ts.net
BETTER_AUTH_URL=http://localhost:3000

# One-time owner bootstrap token (the security crux). The /api/auth/bootstrap
# route creates the single owner ONLY when this exact token is presented AND no
# user exists yet. A tailnet device WITHOUT this token cannot register.
# MUST be high-entropy: this custom route is NOT behind Better Auth's rate
# limiter, so a weak token is brute-forceable in the (pre-owner) window before
# you bootstrap. Generate with:
#   openssl rand -base64 32
# Keep it secret; you only need it once (first run). The window closes the
# instant the owner is created (all later requests 409). If unset, the bootstrap
# route is hard-disabled (fail closed).
AUTH_BOOTSTRAP_TOKEN=

# Owner email — pinned server-side (cosmetic in this single-user system). Set
# only if you want a specific address; default owner@genesis.local is fine.
# AUTH_OWNER_EMAIL=

# Auth database directory (pglite, SEPARATE from the engine store). Created on
# first request. Default if unset: ./.data/auth (relative to the app's cwd).
# NOTE: in a deployment that rebuilds with `next build` (which wipes
# .next/standalone), set this to a path OUTSIDE the build dir, e.g.
# ~/.local/share/genesis-web/auth — otherwise a rebuild erases the owner+passkey.
AUTH_DB_PATH=./.data/auth

# ─── Agent / machine principal (operate + dogfood) ──────────────────────────
# A server-only token that lets the AGENT drive /api/chat without a passkey,
# presented in the `X-Agent-Token` request header (constant-time compared).
# Humans authenticate with passkeys; the agent authenticates with this token —
# it does NOT weaken the human gate (a browser never sends X-Agent-Token, and a
# random tailnet device does not hold this 0600 secret). Unset ⇒ the agent path
# is hard-disabled (fail closed). MUST be high-entropy:
#   openssl rand -base64 32
# Usage:  curl -H "X-Agent-Token: $AGENT_TOKEN" -X POST .../api/chat -d '{...}'
AGENT_TOKEN=
