# ── Genesis configuration ───────────────────────────────────────────────
PORT=8787
GENESIS_WORKSPACE=/path/to/a/git/repo        # local host: where the agent runs
GENESIS_AGENT_ARGS=--dangerously-skip-permissions
# GENESIS_TOKEN=                              # bearer gate for /message + /threads

# ── Durable store (Phase 2) ─────────────────────────────────────────────
# DATABASE_URL=postgres://...                 # → Postgres (Railway). Else pglite:
GENESIS_DATA_DIR=~/.genesis/data             # persistent pglite (FS-as-truth)

# ── Execution host (Phase 4) ────────────────────────────────────────────
# GENESIS_HOST=vercel                         # → microVM tier (Vercel Sandbox)
# Vercel auth — either OIDC (automatic on Vercel; `vercel env pull` locally):
#   VERCEL_OIDC_TOKEN=
# …or an access token (CI / non-Vercel):
#   VERCEL_TOKEN=
#   VERCEL_TEAM_ID=
#   VERCEL_PROJECT_ID=
# Keyed creds boundary-injected into the sandbox (NOT subscription OAuth):
#   ANTHROPIC_API_KEY=
# Sandbox tuning:
#   GENESIS_SANDBOX_NAME=genesis-default      # continuity key (persistent VM)
#   GENESIS_GIT_URL=https://github.com/you/repo   # cloned into the VM at create
#   GENESIS_REMOTE_CWD=/vercel/sandbox        # agent working dir inside the VM
#   GENESIS_SANDBOX_TIMEOUT_MS=2700000        # 45 min
#   GENESIS_SANDBOX_BOOTSTRAP=["npm","i","-g","@anthropic-ai/claude-code"]  # JSON argv (install agent CLI)
# Egress firewall. Default = deny-by-default ALLOW-LIST (api.anthropic.com + npm),
# so the keyed agent reaches the LLM while everything else is blocked. NOTE: this
# default is narrow — tasks that git-push, clone other repos, pip-install, or call
# MCP servers need a WIDER allow-list. Widen via a JSON allow-list object:
#   GENESIS_NETWORK_POLICY={"allow":["api.anthropic.com","github.com","api.github.com","codeload.github.com","registry.npmjs.org","files.pythonhosted.org"]}
# Or "allow-all" (no isolation) / "deny-all" (blocks the LLM — agent won't run):
#   GENESIS_NETWORK_POLICY=allow-all
