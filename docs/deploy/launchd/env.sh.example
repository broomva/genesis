# Genesis Telegram bot — launchd env (copy to ~/.config/genesis-bot/env.sh).
# Owner-specific; keep OUT of git. (BRO-1516)

# launchd's PATH is minimal — add tmux (homebrew), bun, claude or the agent
# can't spawn its children (the ENOENT-tmux failure mode).
export PATH="/opt/homebrew/bin:$HOME/.bun/bin:$HOME/.local/bin:$PATH"

# Engine (BRO-1524): PRINT (`claude -p`) is the default — simple, reliable, no
# tmux/keystroke fragility. `claude -p` draws the subscription at no penalty
# while Anthropic's June-15 Agent-SDK metering stays PAUSED (advance notice
# promised before any return). --dangerously-skip-permissions lets the headless
# agent run tools (gated by the owner allowlist). If metering returns, flip to
# the exempt-insurance interactive engine: set GENESIS_ENGINE=interactive and
# drop GENESIS_AGENT_ARGS.
# export GENESIS_ENGINE=interactive            # exempt-insurance path (tmux PTY)
export GENESIS_AGENT_ARGS="--dangerously-skip-permissions"
export GENESIS_WORKSPACE="$HOME/broomva"      # the real workspace
export GENESIS_NO_WORKTREE=1                   # run in-place (nested git repos)
export GENESIS_DATA_DIR="$HOME/.config/genesis-bot/data"
export GENESIS_BOT_STATE_DIR="$HOME/.config/genesis-bot/state"
export PORT=8787
export GENESIS_URL=http://localhost:8787
export TELEGRAM_BOT_USERNAME=YourBotUsername
export GENESIS_TELEGRAM_ALLOWED_USERS=<your-telegram-chat-id>   # REQUIRED for a real workspace

# Token from a 0600 secret file (NOT in the plist). `set -a` exports the bare
# VAR=value the file uses, so `exec bun` inherits it. (Relocated from the old
# clawdbot ~/.claude/channels path to genesis's own config dir — BRO-1527.)
set -a
source "$HOME/.config/genesis-bot/secrets.env"
set +a
