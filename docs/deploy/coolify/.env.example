# Genesis self-host (Coolify / docker-compose). Copy to `.env`; NEVER commit it.
# In Coolify, set these as the resource's Environment Variables instead.

# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # from @BotFather
GENESIS_TELEGRAM_ALLOWED_USERS=     # your numeric Telegram chat id (DM @userinfobot).
                                    # REQUIRED — the bot is fail-closed and won't
                                    # start without it (no open bot = no RCE-by-DM).
GENESIS_TOKEN=                      # any long random string (e.g. `openssl rand -hex 32`).
                                    # Shared bot↔api bearer; gates the api.
GENESIS_WORKSPACE_HOST=             # host path to the repo(s) the agent may edit,
                                    # e.g. /home/you/projects. REQUIRED — the agent
                                    # operates on this; no silent empty default.

# Subscription auth (FREE, owned hardware). Run `claude setup-token` on any
# machine with a browser (it prints a 1-year token; it does NOT save it), then
# paste it here. Never commit it.
CLAUDE_CODE_OAUTH_TOKEN=

# ── Optional ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_USERNAME=              # bot handle (cosmetic)
CLAUDE_VERSION=stable               # stable | latest | a pinned version e.g. 2.1.89
